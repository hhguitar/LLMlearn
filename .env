SEC_USER_AGENT=yourname youremail

# Qwen / DashScope OpenAI-compatible LLM settings
LLM_PROVIDER=dashscope
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Backward-compatible OpenAI-style vars (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Embedding options
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# If using hosted embeddings through DashScope / OpenAI-compatible API
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL_API=text-embedding-v3

# Chroma path
CHROMA_DIR=data/index/chroma

